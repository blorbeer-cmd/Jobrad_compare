generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

// ---------------------------------------------------------------------------
// Auth models (NextAuth.js managed)
// ---------------------------------------------------------------------------

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  role          Role        @default(USER)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  consentGiven  Boolean     @default(false)
  consentAt     DateTime?

  accounts      Account[]
  sessions      Session[]
  savedBikes    SavedBike[]
  invitesSent   Invite[]    @relation("InviteSender")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invite {
  id        String    @id @default(cuid())
  email     String    @unique
  invitedBy String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime

  sender User @relation("InviteSender", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
}

// ---------------------------------------------------------------------------
// Normalized bike data model (Phase 5)
// ---------------------------------------------------------------------------

/// Known dealer/shop with adapter configuration
model Dealer {
  id            String        @id @default(cuid())
  name          String        @unique
  url           String        @default("")
  adapterKey    String        @unique
  isActive      Boolean       @default(true)
  lastFetchedAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  listings      BikeListing[]

  @@index([adapterKey])
}

/// Canonical bike entity — one row per distinct brand+model combination
model BikeModel {
  id           String        @id @default(cuid())
  brand        String
  modelName    String
  category     String
  /// Normalized key for deduplication: "cube:touring-hybrid-one-625"
  canonicalKey String        @unique
  modelYear    Int?
  createdAt    DateTime      @default(now())

  listings     BikeListing[]

  @@index([brand, modelName])
}

/// Concrete offer from a specific dealer for a specific bike model
model BikeListing {
  id           String          @id @default(cuid())
  bikeModelId  String
  dealerId     String
  /// Unique identifier from the source system (SKU / offer ID)
  sourceId     String?
  sourceType   String          @default("scrape")
  /// Main display price (offerPrice if discounted, otherwise listPrice)
  price        Float
  /// UVP / original list price
  listPrice    Float?
  /// Discounted offer price (when different from listPrice)
  offerPrice   Float?
  url          String
  imageUrl     String?
  availability String?
  lastSeenAt   DateTime        @default(now())
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  bikeModel    BikeModel       @relation(fields: [bikeModelId], references: [id])
  dealer       Dealer          @relation(fields: [dealerId], references: [id])
  snapshots    PriceSnapshot[]
  savedBikes   SavedBike[]

  @@unique([dealerId, sourceId])
  @@index([dealerId])
  @@index([bikeModelId])
  @@index([lastSeenAt])
}

/// Price snapshot — one row each time a price change is detected
model PriceSnapshot {
  id            String      @id @default(cuid())
  bikeListingId String
  price         Float
  listPrice     Float?
  offerPrice    Float?
  recordedAt    DateTime    @default(now())

  bikeListing   BikeListing @relation(fields: [bikeListingId], references: [id], onDelete: Cascade)

  @@index([bikeListingId, recordedAt])
}

// ---------------------------------------------------------------------------
// User favorites
// ---------------------------------------------------------------------------

model SavedBike {
  id             String       @id @default(cuid())
  userId         String
  /// Optional normalized reference — set when the listing is in the DB
  bikeListingId  String?
  /// Denormalized JSON snapshot for offline/demo listings (backwards compat)
  bikeData       Json
  dealer         String
  note           String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bikeListing    BikeListing? @relation(fields: [bikeListingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bikeListingId])
}
